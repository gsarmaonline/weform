# Server
PORT=8080
ENV=development
ALLOWED_ORIGINS=http://localhost:3000

# Database
DATABASE_URL=postgres://weform:weform@localhost:5432/weform?sslmode=disable

# Auth — generate with: openssl rand -base64 32
JWT_SECRET=
JWT_EXPIRY_HOURS=24
REFRESH_EXPIRY_HOURS=168

# Google OAuth — https://console.cloud.google.com/
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# NextAuth (frontend)
AUTH_SECRET=        # can reuse JWT_SECRET or generate separately
AUTH_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8080/api/v1

# SMTP (optional — for email_notification and email_autoresponder workflows)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=noreply@example.com
