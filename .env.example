# Server
PORT=8080
ENV=development
ALLOWED_ORIGINS=http://localhost:3000

# Database
DATABASE_URL=postgres://user:password@localhost:5432/weform?sslmode=disable

# Auth
JWT_SECRET=change-me-run-openssl-rand-base64-32
JWT_EXPIRY_HOURS=24
REFRESH_EXPIRY_HOURS=168

# Google OAuth — https://console.cloud.google.com/
GOOGLE_CLIENT_ID=

# SMTP (for email_notification and email_autoresponder workflows)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=noreply@example.com
